# Copie para docs/secrets.local.env e preencha (gitignored).
# Ver docs/SECRETS_CHECKLIST.md

# --- Ambiente alvo: devnet | mainnet-beta ---
LAUNCH_CLUSTER=devnet

# --- Domínio (produção) ---
DOMAIN=sol-chess.xyz
API_DOMAIN=api.sol-chess.xyz
VITE_ADMIN_BASE_PATH=/r8n4x2k7m9p3/

# --- Solana RPC (Helius recomendado) ---
# Devnet:
RPC_URL=https://devnet.helius-rpc.com/?api-key=SEU_KEY
# Mainnet (quando LAUNCH_CLUSTER=mainnet-beta):
# RPC_URL=https://mainnet.helius-rpc.com/?api-key=SEU_KEY

# Carteira que RECEBE rake (só pubkey)
FEE_RECIPIENT_WALLET=

# Authority — deploy, init-escrow, settle
AUTHORITY_KEYPAIR_PATH=C:\Users\Gusta\.config\solana\id.json

# Após deploy (ou use AcNc9UMC... se já deployado na devnet)
PROGRAM_ID=AcNc9UMCBBzuN8Yb54gspKEZ5h6zT1pFZCd4L89mHx2h

# Rake on-chain global (300 = 3%; por modo: ranked 2%, custom 3%)
HOUSE_RAKE_BPS=300

MOCK_ESCROW=false

# --- MongoDB Atlas (local + produção) ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/sol-chess

# --- Render (API + WebSocket) ---
RENDER_API_KEY=
RENDER_SERVICE_ID=

# --- Vercel (frontend) ---
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- Google OAuth (admin) ---
GOOGLE_CLIENT_ID=

# --- Admin gate ---
ADMIN_GATE_EMAIL=
ADMIN_GATE_GOOGLE_EMAIL=
ADMIN_GATE_WALLET=
ADMIN_SECRET=

# --- CORS ---
CORS_ORIGIN=https://sol-chess.xyz

# --- GitHub (opcional CI) ---
GITHUB_REPO=hgustavo98/solana-chess
GITHUB_TOKEN=
